DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/dotmac_voice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dotmac_voice

REDIS_PASSWORD=redis
REDIS_URL=redis://:redis@localhost:6379/0
CELERY_BROKER_URL=redis://:redis@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis@localhost:6379/1
CELERY_TIMEZONE=UTC

JWT_SECRET=openbao://secret/data/dotmac_voice#jwt_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
TOTP_ISSUER=dotmac_voice
TOTP_ENCRYPTION_KEY=openbao://secret/data/dotmac_voice#totp_key
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_PATH=/

SECRET_KEY=replace-with-a-random-32-byte-secret
METRICS_TOKEN=replace-with-a-random-metrics-token

# CORS — comma-separated origins (leave empty to disable)
CORS_ORIGINS=

BRAND_NAME=DotMac Voice
BRAND_TAGLINE=FastAPI starter
BRAND_LOGO_URL=
BRANDING_UPLOAD_DIR=static/branding
BRANDING_MAX_SIZE_BYTES=5242880
BRANDING_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,image/x-icon,image/vnd.microsoft.icon
BRANDING_URL_PREFIX=/static/branding

OPENBAO_ADDR=
OPENBAO_TOKEN=
OPENBAO_NAMESPACE=
OPENBAO_KV_VERSION=2

CELERY_BEAT_MAX_LOOP_INTERVAL=5
CELERY_BEAT_REFRESH_SECONDS=30

OTEL_ENABLED=false
OTEL_SERVICE_NAME=dotmac_voice
OTEL_EXPORTER_OTLP_ENDPOINT=

FUSIONPBX_API_URL=http://localhost:8080
FUSIONPBX_API_KEY=
ESL_HOST=localhost
ESL_PORT=8021
ESL_PASSWORD=replace-with-freeswitch-esl-password
EDGE_WSS_URL=wss://sip.dotmac.io:443
VOICE_INGRESS_API_KEYS=replace-with-random-ingress-key
VOICE_INGRESS_ALLOWED_IPS=
TOKEN_SIGNING_KEY=replace-with-a-random-token-signing-key
